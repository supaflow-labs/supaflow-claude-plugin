{
  "description": "Verify Supaflow CLI setup on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-setup.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
